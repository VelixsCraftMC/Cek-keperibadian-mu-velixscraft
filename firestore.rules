rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: results
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required) - The UID of the user
    //   - displayName: string (required) - User's name
    //   - photoURL: string (required) - User's profile pic
    //   - category: string (required) - The quiz result category
    //   - scores: map (required) - Detailed scores
    //   - timestamp: timestamp (required) - Creation time
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidResult(data) {
      return data.keys().hasAll(['userId', 'displayName', 'photoURL', 'category', 'totalPoints', 'scores', 'timestamp']) &&
             data.userId is string && data.userId == request.auth.uid &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             data.photoURL is string &&
             data.category in ['femboy', 'tomboy', 'normal', 'abnormal', 'jujur_cewek', 'jujur_cowok'] &&
             data.totalPoints is number &&
             data.scores is map &&
             data.timestamp == request.time;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['userId', 'displayName', 'photoURL', 'text', 'timestamp']) &&
             data.userId is string && data.userId == request.auth.uid &&
             data.displayName is string && data.displayName.size() > 0 &&
             data.text is string && data.text.size() > 0 && data.text.size() < 500 &&
             data.timestamp == request.time;
    }

    match /results/{resultId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidResult(request.resource.data);
      allow update, delete: if false;
    }

    match /messages/{messageId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidMessage(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if false;
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
